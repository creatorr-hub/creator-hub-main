{
  "name": "creator-hub-frontend",
  "version": "0.1.0",
  "description": "Landing page and dashboard for Creator Hub",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext ts,tsx",
    "lint:fix": "eslint src --ext ts,tsx --fix",
    "format": "prettier --write 'src/**/*.{ts,tsx}'",
    "type-check": "tsc --noEmit",
    "env:setup": "cp .env.example .env.local",
    "env:check": "node -e \"require('dotenv').config(); console.log('✓ Environment loaded:', process.env.REACT_APP_API_URL)\""
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.18.0",
    "axios": "^1.6.0",
    "@freighterapp/freighter-api": "^4.0.0",
    "stellar-sdk": "^11.0.0",
    "@tailwindcss/forms": "^0.5.0",
    "lucide-react": "^0.294.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "vite": "^4.5.0",
    "typescript": "^5.0.0",
    "eslint": "^8.50.0",
    "eslint-config-airbnb-typescript": "^17.1.0",
    "prettier": "^3.0.0",
    "tailwindcss": "^3.3.0",
    "postcss": "^8.4.0",
    "autoprefixer": "^10.4.0"
  }
}
