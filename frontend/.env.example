# Frontend Environment Variables Template
# Copy this to .env.local and fill in your values

# Backend API Configuration
REACT_APP_API_URL=http://localhost:3001

# Stellar Network Configuration
# Options: testnet, public
REACT_APP_STELLAR_NETWORK=testnet

# Freighter Wallet Configuration
REACT_APP_FREIGHTER_ENABLED=true

# API Endpoints (derived from above)
REACT_APP_API_BASE_URL=http://localhost:3001/api/v1

# Application
REACT_APP_APP_NAME=Creator Hub
REACT_APP_APP_VERSION=0.1.0

# Debug Mode
REACT_APP_DEBUG=false

# Logging
REACT_APP_LOG_LEVEL=info

# Feature Flags (for future use)
REACT_APP_ENABLE_NOTIFICATIONS=false
REACT_APP_ENABLE_ANALYTICS=false

# Timeouts (in milliseconds)
REACT_APP_API_TIMEOUT=30000
REACT_APP_TRANSACTION_TIMEOUT=120000

# Cache Configuration
REACT_APP_CACHE_ENABLED=true
REACT_APP_CACHE_TTL=3600

# Payment Configuration
REACT_APP_DEFAULT_PAYMENT_TOKEN=XLM
REACT_APP_MIN_PAYMENT_AMOUNT=1
REACT_APP_MAX_PAYMENT_AMOUNT=1000000
