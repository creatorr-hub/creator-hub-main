{
  "name": "creator-hub-backend",
  "version": "0.1.0",
  "description": "Backend API for Creator Hub",
  "main": "dist/app.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --inspect src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "lint": "eslint src --ext ts",
    "lint:fix": "eslint src --ext ts --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "migrate:latest": "node -r tsx/cjs src/migrations/run.ts",
    "seed": "tsx src/seeds/seed.ts",
    "test": "vitest",
    "test:coverage": "vitest --coverage"
  },
  "dependencies": {
    "express": "^4.18.2",
    "pg": "^8.10.0",
    "stellar-sdk": "^11.0.0",
    "jsonwebtoken": "^9.1.0",
    "dotenv": "^16.0.3",
    "express-validator": "^7.0.0",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "morgan": "^1.10.0",
    "bcrypt": "^5.1.0",
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.10.0",
    "@types/bcrypt": "^5.0.0",
    "typescript": "^5.0.0",
    "tsx": "^3.13.0",
    "eslint": "^8.50.0",
    "eslint-config-airbnb-typescript": "^17.1.0",
    "prettier": "^3.0.0",
    "vitest": "^0.34.0"
  }
}
